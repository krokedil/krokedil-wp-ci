# .env.example — krokedil-wp-ci
# Copy to .env and fill in values as needed.

# =============================================================================
# Plugin credentials (used locally and as GitHub repo secrets)
# =============================================================================
# Plugin-specific variables follow the naming convention:
#   {PLUGIN_ABBREV}_{OPTION_NAME}
# For example, Klarna Checkout (KCO) uses the KCO_ prefix.
# These are used by blueprint generators both locally and in CI workflows.

# Klarna Checkout for WooCommerce (KCO)
KCO_TEST_MERCHANT_ID_EU=
KCO_TEST_SHARED_SECRET_EU=

# =============================================================================
# Local development
# =============================================================================

# PHP versions to use when running plugin dev zip e2e tests locally.
#KROKEDIL_TEST_PHP_VERSIONS=8.3          # Comma-separated, e.g. "8.2,8.3" or "all"

# Local plugin directories for scripts/playground.js.
# When set, `npm run playground -- kp` uses this directory instead of cloning.
# Variable name: {ABBREVIATION}_LOCAL_DIR (abbreviation from .github/plugins.json)
#KP_LOCAL_DIR=/Users/username/Projects/klarna-payments
#KCO_LOCAL_DIR=/Users/username/Projects/klarna-checkout
#BUDBEE_LOCAL_DIR=/Users/username/Projects/budbee
#SWEDBANK_LOCAL_DIR=/Users/username/Projects/swedbank

# =============================================================================
# GitHub repo secrets
# =============================================================================
# These should be configured as repository secrets in GitHub, not in .env.
# Listed here for reference.

# GitHub PAT — used by centrally-* workflows to check out external plugin repos
#CLASSIC_PERSONAL_ACCESS_TOKEN=

# AWS — used by the plugin dev zip upload workflow
#AWS_ACCESS_KEY_ID_KROKEDIL_PLUGIN_DEV_ZIP=
#AWS_SECRET_ACCESS_KEY_KROKEDIL_PLUGIN_DEV_ZIP=

# Slack — e2e test notification webhook
#SLACK_WEBHOOK_URL_KROKEDIL_E2E_NOTIFICATIONS=

# InstaWP — deployment workflows
#INSTAWP_API_TOKEN=
