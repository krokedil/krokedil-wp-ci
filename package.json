{
  "name": "krokedil-wp-ci",
  "version": "1.0.0",
  "private": true,
  "description": "Reusable CI workflows and actions for Krokedil WordPress/WooCommerce plugins",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "npm run lint:sh && npm run lint:js",
    "lint:sh": "shellcheck scripts/*.sh scripts/**/*.sh",
    "lint:js": "eslint scripts/",
    "test:scripts": "node --test tests/scripts",
    "sync:plugins": "node scripts/sync-plugin-list.js",
    "check:plugins": "node scripts/sync-plugin-list.js --check",
    "playground": "node scripts/playground.js"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jq": "^1.7.2"
  },
  "devDependencies": {
    "@wp-playground/cli": "^3.1.13",
    "eslint": "^9.39.4",
    "playwright": "^1.59.0"
  }
}
